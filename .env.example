# Server
AGENTOS_HOST=127.0.0.1
AGENTOS_PORT=8765
AGENTOS_SERVER_NAME=agentos

# Database
DATABASE_URL=sqlite:///./agentos.db

# Vector Store (ChromaDB)
CHROMA_PERSIST_DIR=./chroma_store
CHROMA_COLLECTION_NAME=agentos_memories

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2    # local sentence-transformers model

# Memory Settings
MEMORY_DECAY_RATE=0.01              # per day
MEMORY_MAX_PER_AGENT=10000

# Reflection
REFLECTION_LOOKBACK_DAYS=7
PATTERN_MIN_FREQUENCY=3            # minimum occurrences to flag as pattern

# Logging
LOG_LEVEL=INFO
LOG_FILE=./agentos.log

# Gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8080
GATEWAY_SECRET=change-me-please

# Webhook (set WEBHOOK_ENABLED=true and provide URL to activate)
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-service.com/webhook
WEBHOOK_SECRET=your-webhook-secret
